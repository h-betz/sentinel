# Database
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel_secret@localhost:5432/sentinel  # pragma: allowlist secret
DATABASE_URL_SYNC=postgresql://sentinel:sentinel_secret@localhost:5432/sentinel  # pragma: allowlist secret

# Database Pool Settings (small pool to trigger N+1 deadlock)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=0

# Payment Service
PAYMENT_SERVICE_URL=http://localhost:8001

# App Settings
DEBUG=true

# Sentinel AI Agent
ANTHROPIC_API_KEY=your_anthropic_api_key_here
